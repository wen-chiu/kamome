{
  "version": 8,
  "name": "Kamome Functional Base",
  "metadata": {
    "kamome:role": "functional-substrate",
    "kamome:note": "Replay MVP §2 substrate — a deliberately unstyled, subtractive base so MapLibre frames render. NOT the shipping look: Modern Minimal (§3, Config/RecapThemes/modern-minimal.json) supersedes this after Chiu's design review. Authored by hand (start empty, add layers); iterate in Maputnik pointed at the local fixture tiles — see README.md.",
    "kamome:schema": "OpenMapTiles (Planetiler default)"
  },
  "sources": {
    "kamome": {
      "type": "vector",
      "url": "pmtiles://__KAMOME_TILES__",
      "attribution": "© OpenMapTiles © OpenStreetMap contributors",
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "land",
      "type": "background",
      "paint": {
        "background-color": "#ededE8"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "kamome",
      "source-layer": "water",
      "filter": ["all", ["==", "$type", "Polygon"], ["!=", "intermittent", 1]],
      "paint": {
        "fill-color": "#c9d6db",
        "fill-antialias": true
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "kamome",
      "source-layer": "waterway",
      "minzoom": 9,
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": "#c9d6db",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.6, 14, 1.4]
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "kamome",
      "source-layer": "landcover",
      "minzoom": 7,
      "filter": ["all", ["==", "$type", "Polygon"], ["==", "class", "wood"]],
      "paint": {
        "fill-color": "#e4e6df",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "kamome",
      "source-layer": "transportation",
      "minzoom": 12,
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "service", "residential"]],
      "paint": {
        "line-color": "#e0ded6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 14, 1.2]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "kamome",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "secondary", "tertiary"]],
      "paint": {
        "line-color": "#dcd9d0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 14, 2.2]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "kamome",
      "source-layer": "transportation",
      "minzoom": 6,
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "primary", "trunk", "motorway"]],
      "paint": {
        "line-color": "#d5d1c6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 10, 1.6, 14, 3.4]
      }
    }
  ]
}

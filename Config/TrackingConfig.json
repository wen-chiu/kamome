{
  "schema_version": 1,
  "filter": {
    "max_h_acc_m": 50
  },
  "segmentation": {
    "mode_confirm_s": 60,
    "speed_smoothing_window_s": 30,
    "speed_stationary_max_kmh": 1.5,
    "speed_walk_max_kmh": 6,
    "speed_drive_min_kmh": 20,
    "speed_transit_min_kmh": 130
  },
  "dwell": {
    "window_s": 180,
    "radius_m": 80,
    "region_radius_m": 150
  },
  "simplify": {
    "epsilon_m": 15
  },
  "sampling": {
    "walk": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 10 },
    "vehicles": {
      "car": {
        "fast_min_kmh": 20,
        "fast": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 50 },
        "slow": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 20 }
      },
      "scooter": {
        "fast_min_kmh": 15,
        "fast": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 30 },
        "slow": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 15 }
      },
      "bicycle": {
        "fast_min_kmh": 12,
        "fast": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 20 },
        "slow": { "desired_accuracy": "nearest_ten_meters", "distance_filter_m": 10 }
      }
    }
  },
  "export": {
    "target_duration_s": 30,
    "fps": 30,
    "stop_hold_s": 1.5,
    "gif_fps": 12,
    "gif_width_px": 480
  }
}

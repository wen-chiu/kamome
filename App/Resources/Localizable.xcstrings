    "priming_body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose \"Change to Always Allow\" so your route keeps recording with the screen locked. Kamome only ever tracks during a trip you started, and stops the moment you end it."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請選擇「永遠允許」，即使螢幕鎖定也能持續記錄路線。卡摸咩只在您啟動的旅程期間記錄，旅程結束立即停止。"
          }
        }
      }
    },
